:root {
    --site--max-width: min(var(--site--width), 100vw);
    --container--main: calc(var(--site--max-width) - var(--site--margin) * 2);
    --container--full: calc(100vw - var(--site--margin) * 2);
    --container--small: calc(var(--column-width--plus-gutter) * (var(--site--column-count) - 4) - var(--site--gutter));
    --site--gutter-total: calc(var(--site--gutter) * (var(--site--column-count) - 1));
    --column-width--1: calc((var(--container--main) - var(--site--gutter-total)) / var(--site--column-count));
    --column-width--plus-gutter: calc(var(--column-width--1) + var(--site--gutter));
    --column-width--2: calc(var(--column-width--plus-gutter) * 2 - var(--site--gutter));
    --column-width--3: calc(var(--column-width--plus-gutter) * 3 - var(--site--gutter));
    --column-width--4: calc(var(--column-width--plus-gutter) * 4 - var(--site--gutter));
    --column-width--5: calc(var(--column-width--plus-gutter) * 5 - var(--site--gutter));
    --column-width--6: calc(var(--column-width--plus-gutter) * 6 - var(--site--gutter));
    --column-width--7: calc(var(--column-width--plus-gutter) * 7 - var(--site--gutter));
    --column-width--8: calc(var(--column-width--plus-gutter) * 8 - var(--site--gutter));
    --column-width--9: calc(var(--column-width--plus-gutter) * 9 - var(--site--gutter));
    --column-width--10: calc(var(--column-width--plus-gutter) * 10 - var(--site--gutter));
    --column-width--11: calc(var(--column-width--plus-gutter) * 11 - var(--site--gutter));
    --column-width--12: calc(var(--column-width--plus-gutter) * 12 - var(--site--gutter));
    --column-margin--1: calc(var(--column-width--plus-gutter) * 1);
    --column-margin--2: calc(var(--column-width--plus-gutter) * 2);
    --column-margin--3: calc(var(--column-width--plus-gutter) * 3);
    --column-margin--4: calc(var(--column-width--plus-gutter) * 4);
    --column-margin--5: calc(var(--column-width--plus-gutter) * 5);
    --column-margin--6: calc(var(--column-width--plus-gutter) * 6);
    --column-margin--7: calc(var(--column-width--plus-gutter) * 7);
    --column-margin--8: calc(var(--column-width--plus-gutter) * 8);
    --column-margin--9: calc(var(--column-width--plus-gutter) * 9);
    --column-margin--10: calc(var(--column-width--plus-gutter) * 10);
    --column-margin--11: calc(var(--column-width--plus-gutter) * 11);
    --column-margin--12: calc(var(--column-width--plus-gutter) * 12);
    --breakout-start: [full-start] minmax(0, 1fr) [content-start];
    --breakout-end: [content-end] minmax(0, 1fr) [full-end];
    --grid-breakout-single: var(--breakout-start) minmax(0, var(--container--main)) var(--breakout-end);
    --grid-breakout: var(--breakout-start) repeat(var(--site--column-count), minmax(0, var(--column-width--1))) var(--breakout-end);
    --_typography---text-transform--none: none;
    --_typography---text-transform--uppercase: uppercase;
    --_typography---text-transform--captialize: capitalize;
    --_typography---text-transform--lowercase: lowercase;
    --align--start: start;
    --align--center: center;
    --align--end: end;
}
* {
	vertical-align: bottom;
}
::before, ::after {
	box-sizing: border-box;
}
html {
	background-color: var(--_theme---background);
}
button {
	background-color: unset;
	padding: unset;
	text-align: inherit;
}
button:not(:disabled) {
	cursor: pointer;
}
video {
	width: 100%;
	object-fit: cover;
}
/* remove padding of empty element */
.wf-empty {
	padding: 0;
}
svg {
	max-width: 100%;
}
section, header, footer {
	position: relative;
}
@media (prefers-color-scheme: light) {
	option { color: black; }
}
img::selection {
	background: transparent;
}
/* Typography */
body {
	text-transform: var(--_text-style---text-transform);
	font-smoothing: antialiased;
	-webkit-font-smoothing: antialiased;
}
/* Clear Defaults */
a:not([class]) {
	text-decoration: underline;
}
h1,h2,h3,h4,h5,h6,p,blockquote,label {
	font-family: inherit;
	font-size: inherit;
	font-weight: inherit;
	line-height: inherit;
	letter-spacing: inherit;
	text-transform: inherit;
	text-wrap: inherit;
	margin-top: 0;
	margin-bottom: 0;
}
/* Selection Color */
::selection {
	background-color: var(--_theme---selection--background);
	color: var(--_theme---selection--text);
}
/* Margin Trim */
:is(.u-margin-trim, .u-rich-text) > :not(:not(.w-condition-invisible) ~ :not(.w-condition-invisible)) {
	margin-top: 0;
}
:is(.u-margin-trim, .u-rich-text) > :not(:has(~ :not(.w-condition-invisible))) {
	margin-bottom: 0;
}
/* Line Height Trim */
:is([class*="u-text-style-"],h1,h2,h3,h4,h5,h6,p):not(.w-richtext,.u-text-trim-off)::before {
	content: "";
	display: table;
	margin-bottom: calc(-0.5lh + var(--_text-style---trim-top));
}
:is([class*="u-text-style-"],h1,h2,h3,h4,h5,h6,p):not(.w-richtext,.u-text-trim-off)::after {
	content: "";
	display: table;
	margin-bottom: calc(-0.5lh + var(--_text-style---trim-bottom));
}
/* Rich Text Links */
.w-richtext a {
	position: relative;
	z-index: 4;
}
/* Line Clamp */
.u-line-clamp-1, .u-line-clamp-2, .u-line-clamp-3, .u-line-clamp-4 {
	-webkit-line-clamp: 1;
	-webkit-box-orient: vertical;
}
.u-line-clamp-2 { -webkit-line-clamp: 2; }
.u-line-clamp-3 { -webkit-line-clamp: 3; }
.u-line-clamp-4 { -webkit-line-clamp: 4; }
/* Child Contain */
.u-child-contain > * {
	width: 100%;
	max-width: inherit !important;
  margin-inline: 0 !important;
	margin-top: 0 !important;
}
/* Hide */
.u-hide-if-empty:empty,
.u-hide-if-empty:not(:has(> :not(.w-condition-invisible))),
.u-hide-if-empty-cms:not(:has(.w-dyn-item)),
.u-embed-js,
.u-embed-css {
	display: none !important;
}
/* Focus State */
a, button, :where([tabindex]) {
	outline-offset: var(--focus--offset-outer);
}
a:focus-visible,
button:focus-visible,
[tabindex]:focus-visible {
	outline-color: var(--_theme---text);
	outline-width: var(--focus--width);
	outline-style: solid;
}
/* Global / Clickable Component */
.wf-design-mode .g_clickable_wrap {
	z-index: 0;
}
.g_clickable_wrap a[href="#"] {
	display: none;
}
.g_clickable_wrap a[href="#"] ~ button {
	display: block;
}
/* Responsive */
@container (width < 62em) {
	.u-grid-from-large { display: flex; }
}
@container (width < 48em) {
	.u-grid-from-medium { display: flex; }
}
@container (width < 30em) {
	.u-grid-from-small { display: flex; }
}
</style></div><div class="page_code_custom w-embed"><style>

/* TYPOGRAPHY */

.g_heading strong {
	font-weight: inherit;
  display: block;
}

.g_convert_icon img {
	object-fit: contain;
}

#overlay-fade {
  background: linear-gradient(90deg, var(--_theme---background) 0%, rgba(0, 0, 0, 0.00) 25.48%, rgba(0, 0, 0, 0.00) 75%, var(--_theme---background) 100%);
}

@media screen and (min-width: 1920px) {
	#overlay-fade {
  	opacity: 1!important;
  }
}

#visual-fade {
	max-width: 120rem;
  margin-left: auto;
  margin-right: auto;
}

.page_wrap:has(.banner_wrap, .nav_anchor_wrap) section:first-of-type [data-wf--global-section-space--section-space="page-top"] {
	height: calc(var(--_spacing---section-space--page-top) + (2 * var(--_spacing---space--2)) + var(--_typography---font-size--text-main));
}

:root {
	--site--large-width: min(var(--site--width-large), 100vw);
  --container--large: calc(var(--site--large-width) - var(--site--margin) * 2);
/*
  @media screen and (max-width: 991px) {
    --container--small: calc(var(--column-width--plus-gutter) * (var(--site--column-count) - 2) - var(--site--gutter));
    h1,h2,h3,h4,h5,h6,p,blockquote,label {
      text-wrap: auto;
    }
  }
*/
  @media screen and (max-width: 478px) {
    --container--small: calc(var(--column-width--plus-gutter) * var(--site--column-count) - var(--site--gutter));
    
    .u-alignment-center {
    	text-align: left;
    }
    
    .btn_main_wrap {
      width: 100%;
    }	
  }
}

/* fade out other footer links when link is hovered */
@media (hover: hover) and (pointer: fine) {
	body:has(.footer_1_group_item:hover) .footer_1_group_item:not(:hover) > * > * {
		opacity: 0.5;
	}
}

/* VISUAL TOGGLES */

.g_visual_img.is-dark,
.g_visual_img.is-light, .g_visual_video.is-light, .g_visual_video.is-dark {
  transition: opacity 0s ease;
}

.page_wrap:not(.u-theme-light) :is(.g_visual_img.is-light, .g_visual_video.is-light) {
  opacity: 1;
}

.page_wrap:not(.u-theme-light) :is(.g_visual_img.is-dark, .g_visual_video.is-dark) {
  opacity: 0;
}

.page_wrap.u-theme-light :is(.g_visual_img.is-dark, .g_visual_video.is-dark) {
  opacity: 1;
}

.page_wrap.u-theme-light :is(.g_visual_img.is-light, .g_visual_video.is-light) {
  opacity: 0;
}

.wf-design-mode .nav_2_dropdown_component > .w-dropdown-list {
	visibility: visible;
	opacity: 1;
}

.btn_main_wrap:hover .btn_main_bg {
	left: 0.125rem;
  top: 0.125rem;
  right: 0.125rem;
  bottom: 0.125rem;
  background-color: var(--_button-style---background-hover);
}

[anm-stagger-btn="text"] {
  white-space: nowrap;
}

.u-theme-light .news_card_meta_txt {
	color: var(--swatch--red);
}

.u-theme-light .nav_message_wrap {
	background-color: var(--swatch--black);
}

.u-theme-light .toggle_sun {
  color: var(--_theme---background-inverted);
}

.u-theme-light .toggle_moon {
  color: var(--_theme---border);
}

.list_column_list_item:not(:last-child) {
	margin-bottom: var(--_spacing---space--5);
}

.g_convert_icon .g_visual_img {
	opacity: 0;
}

@media (hover: hover) and (pointer: fine) {
	.news_card > * > * {
		transition: opacity 300ms cubic-bezier(0.4, 0, 0.2, 1); /* standard ease-in-out curve */
	}

	body:has(.news_card:hover) .news_card:not(:hover) > * > * {
		opacity: 0.5;
	}
}

</style></div><div class="u-embed-js w-embed w-script"><script>
document.addEventListener("DOMContentLoaded", function () {
  const debounce = (func, wait) => {
    let timeout;
    return function (...args) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(this, args), wait);
    };
  };

  document.querySelectorAll(".page_main").forEach((element) => {
    if (element.dataset.scriptInitialized) return;
    element.dataset.scriptInitialized = "true";

    /* BUTTON HOVER — keep exact effect, optimize init */
    function buttonStaggerAnimation() {
      const BTN_SEL = '[anm-stagger-btn=wrap]';
      const TXT_SEL = '[anm-stagger-btn=text]';
      const fontsReady = ('fonts' in document) ? document.fonts.ready : Promise.resolve();

      // lazy pre-warm when near viewport
      const io = new IntersectionObserver((entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          if (!isIntersecting) return;
          const s = ensureState(target);
          const run = () => fontsReady.then(() => { if (!s.built) build(target, s); });
          (window.requestIdleCallback ? requestIdleCallback(run, { timeout: 800 }) : setTimeout(run, 0));
          io.unobserve(target);
        });
      }, { rootMargin: '200px 0px' });

      const ro = new ResizeObserver((entries) => {
        for (const { target } of entries) {
          const s = state.get(target);
          if (!s?.built) continue;
          const rebuild = () => {
            s.splitOriginal?.revert();
            s.splitClone?.revert();
            s.tl.clear();
            s.built = false;
            build(target, s);
          };
          (window.requestIdleCallback ? requestIdleCallback(rebuild, { timeout: 700 }) : setTimeout(rebuild, 50));
        }
      });

      const state = new WeakMap();

      function ensureState(btn) {
        let s = state.get(btn);
        if (s) return s;
        const text = btn.querySelector(TXT_SEL);
        if (!text) return {};
        const opts = {
          direction: btn.getAttribute('anm-direction') || 'up',
          reverseOnLeave: btn.getAttribute('anm-reverse') === 'true',
          stagger: parseFloat(btn.getAttribute('anm-stagger')) || 0.0075,
          delay: parseFloat(btn.getAttribute('anm-delay')) || 0,
          duration: parseFloat(btn.getAttribute('anm-duration')) || 0.5,
          ease: btn.getAttribute('anm-ease') || 'power3.inOut',
          custom: (btn.getAttribute('anm-custom') || '')
            .split(',').reduce((acc, pair) => {
              const [k, v] = pair.split(':').map(s => (s||'').trim());
              if (k && v) acc[k] = v;
              return acc;
            }, {})
        };
        s = { built: false, tl: null, splitOriginal: null, splitClone: null, text, textClone: null, opts };
        state.set(btn, s);
        return s;
      }

      function build(btn, s) {
        if (s.built) return;
        if (!s.textClone) {
          s.textClone = s.text.cloneNode(true);
          Object.assign(s.textClone.style, {
            position: 'absolute', top: 0, left: 0, width: '100%', pointerEvents: 'none'
          });
          s.text.after(s.textClone);
        }
        s.splitOriginal?.revert();
        s.splitClone?.revert();
        s.splitOriginal = new SplitText(s.text, { type: 'chars' });
        s.splitClone    = new SplitText(s.textClone, { type: 'chars' });

        const { direction, stagger, delay, duration, ease, custom } = s.opts;
        const tl = gsap.timeline({ defaults: { ease, delay, duration, stagger }, paused: true });
        const toState = {};
        for (const [k, val] of Object.entries(custom)) {
          toState[k] = (k === 'opacity') ? '1' : val.replace(/(\d+(\.\d+)?)([a-z%]*)/, '0$3');
        }

        if (direction === 'down') {
          tl.fromTo(s.splitOriginal.chars, { yPercent: 0,   ...custom }, { yPercent: 100,  ...toState })
            .fromTo(s.splitClone.chars,   { yPercent: -100, ...custom }, { yPercent: 0,    ...toState }, '<');
        } else {
          tl.fromTo(s.splitOriginal.chars, { yPercent: 0,   ...custom }, { yPercent: -100, ...toState })
            .fromTo(s.splitClone.chars,   { yPercent: 100,  ...custom }, { yPercent: 0,    ...toState }, '<');
        }

        s.tl = tl;
        s.built = true;
        ro.observe(btn);
      }

      document.querySelectorAll(BTN_SEL).forEach((btn) => {
        const s = ensureState(btn);
        if (!s.text) return;
        io.observe(btn);
        const playNow = () => { if (!s.built) build(btn, s); s.tl && s.tl.restart(); };
        btn.addEventListener('mouseenter', playNow, { passive: true });
        btn.addEventListener('focusin',    playNow, { passive: true });
        btn.addEventListener('mouseleave', () => {
          if (!s.tl) return;
          if (s.opts.reverseOnLeave) s.tl.reverse();
          else s.tl.pause(0);
        }, { passive: true });
      });
    }
    buttonStaggerAnimation();
    
    /* NAV THEME MANAGEMENT */
    const nav = document.querySelector(".nav_2_component");
    const pageWrap = document.querySelector(".page_wrap");
    if (!nav || !pageWrap) return;

    const navHeight = parseFloat(
      getComputedStyle(document.documentElement).getPropertyValue("--nav_2--height") || "72"
    );

    function getNavThemeClass(type) {
      const isLight = pageWrap.classList.contains("u-theme-light");
      if (type === "invert") return isLight ? "u-theme-dark" : "u-theme-light";
      if (type === "dark") return "u-theme-dark";
      return "";
    }

    function updateNavThemeOnScroll() {
      nav.classList.remove("u-theme-dark", "u-theme-light");
      let appliedClass = "";
      document.querySelectorAll("[nav-dark], [nav-invert]").forEach((section) => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= navHeight && rect.bottom >= navHeight) {
          const themeType = section.hasAttribute("nav-invert") ? "invert" : "dark";
          const themeClass = getNavThemeClass(themeType);
          if (!appliedClass) appliedClass = themeClass;
        }
      });
      if (appliedClass) nav.classList.add(appliedClass);
    }

    (function () {
      const savedTheme = sessionStorage.getItem("theme");
      if (savedTheme) {
        pageWrap.classList.toggle("u-theme-light", savedTheme === "light");
      }
      document.body.addEventListener("click", function (e) {
        if (e.target.closest(".toggle_wrap")) {
          const isLight = pageWrap.classList.toggle("u-theme-light");
          sessionStorage.setItem("theme", isLight ? "light" : "dark");
          updateNavThemeOnScroll();
        }
      });
    })();

    document.querySelectorAll("[nav-dark], [nav-invert]").forEach((section) => {
      const themeType = section.hasAttribute("nav-invert") ? "invert" : "dark";
      ScrollTrigger.create({
        trigger: section,
        start: `top top+=${navHeight}`,
        end: `bottom top+=${navHeight}`,
        onEnter: () => nav.classList.add(getNavThemeClass(themeType)),
        onLeave: () => nav.classList.remove(getNavThemeClass(themeType)),
        onEnterBack: () => nav.classList.add(getNavThemeClass(themeType)),
        onLeaveBack: () => nav.classList.remove(getNavThemeClass(themeType)),
      });
    });

    window.addEventListener("scroll", debounce(updateNavThemeOnScroll, 100));
    window.addEventListener("resize", debounce(updateNavThemeOnScroll, 200));

    /** ICON CONVERTER — on-view + cache + idle + limited concurrency **/
    (function () {
      const ATTR_INIT = 'data-icon-initialized';
      const svgCache = new Map();
      const maxConcurrent = 3;
      const queue = [];
      let active = 0;

      function fetchSVG(url) {
        if (!svgCache.has(url)) {
          svgCache.set(url, fetch(url).then(r => r.text()).catch(err => {
            svgCache.delete(url);
            throw err;
          }));
        }
        return svgCache.get(url);
      }

      function updateIconDOM(iconEl, svgText, imgEl, svgTarget) {
        const updated = svgText
          .replace(/#(?:fff|ffffff)\b|\bwhite\b/gi, 'currentColor')
          .replace(/#3a3a3a/gi, 'var(--_theme---border)')
          .replace(/<svg([^>]*)>/, (m, attrs) =>
            `<svg${attrs.replace(/\s(width|height)="[^"]*"/gi,'')} width="100%" height="100%">`
          );
        svgTarget.innerHTML = updated;
        const visualWrap = imgEl.closest('.g_visual_wrap');
        if (visualWrap) visualWrap.style.display = 'none';
      }

      function processNext() {
        if (active >= maxConcurrent || queue.length === 0) return;
        active++;
        const job = queue.shift();
        const { icon, imgEl, svgTarget } = job;
        fetchSVG(imgEl.src)
          .then(svgText => {
            const run = () => updateIconDOM(icon, svgText, imgEl, svgTarget);
            if ('requestIdleCallback' in window) {
              requestIdleCallback(run, { timeout: 800 });
            } else {
              setTimeout(run, 0);
            }
          })
          .catch(err => console.error('❌ Failed to load SVG:', err))
          .finally(() => {
            active--;
            processNext();
          });
      }

      function enqueue(icon) {
        const imgEl = icon.querySelector('.g_visual_img');
        const svgTarget = icon.querySelector('.g_svg');
        if (!imgEl || !svgTarget) return;
        queue.push({ icon, imgEl, svgTarget });
        processNext();
      }

      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target;
          if (el.getAttribute(ATTR_INIT)) return;
          el.setAttribute(ATTR_INIT, '1');
          enqueue(el);
          obs.unobserve(el);
        });
      }, { rootMargin: '250px 0px' });

      document.querySelectorAll('.g_convert_icon').forEach(el => io.observe(el));
    })();

    window.Webflow ||= [];
    window.Webflow.push(() => {
      function getResponsiveSpacingInPixels() {
        const temp = document.createElement('div');
        temp.style.marginLeft = 'var(--_spacing---space--2)';
        temp.style.visibility = 'hidden';
        temp.style.position = 'absolute';
        document.body.appendChild(temp);
        const spacing = parseFloat(getComputedStyle(temp).marginLeft);
        document.body.removeChild(temp);
        return spacing;
      }

      const spacing = getResponsiveSpacingInPixels();
      window.swipers = window.swipers || [];

      document.querySelectorAll(".carousel_contain").forEach(container => {
        const swiperEl = container.querySelector(".swiper.is-carousel");
        if (!swiperEl) return;
        const swiper = new Swiper(swiperEl, {
          slidesPerView: "auto",
          spaceBetween: spacing,
          loop: false,
          navigation: {
            nextEl: container.querySelector('.swiper-next'),
            prevEl: container.querySelector('.swiper-prev'),
          },
        });
        window.swipers.push(swiper);
      });

      if (window.innerWidth > 478) {
        document.querySelectorAll(".news_carousel_wrap").forEach(container => {
          const swiperEl = container.querySelector(".swiper.is-carousel");
          if (!swiperEl) return;
          const swiper = new Swiper(swiperEl, {
            slidesPerView: "auto",
            spaceBetween: spacing,
            loop: false,
            navigation: {
              nextEl: container.querySelector('.swiper-next'),
              prevEl: container.querySelector('.swiper-prev'),
            },
          });
          window.swipers.push(swiper);
        });
      }
    });

    /* NAV DROPDOWNS */
    document.querySelectorAll('.nav_2_dropdown_component').forEach(d => {
      const items = d.querySelectorAll('.nav_2_dropdown_item');
      const area = d.querySelector('.nav_2_dropdown_main_wrap');
      const toggle = d.querySelector('.w-dropdown-toggle');

      let enterAnim, leaveAnim;
      let hideTimeout;

      const isMobile = window.matchMedia('(max-width: 64em)').matches;

      if (isMobile) {
        toggle.addEventListener('click', e => {
          e.preventDefault();
          document.querySelectorAll('.nav_2_dropdown_component').forEach(other => {
            if (other !== d) {
              other.classList.remove('hovered');
              gsap.set(other.querySelectorAll('.nav_2_dropdown_item'), { autoAlpha: 0 });
              gsap.set(other.querySelector('.nav_2_dropdown_main_wrap'), { opacity: 0 });
            }
          });
          const isOpen = d.classList.toggle('hovered');
          if (isOpen) {
            gsap.set(area, { opacity: 1 });
            enterAnim = gsap.fromTo(items, { autoAlpha: 0 }, {
              autoAlpha: 1,
              duration: 0.6,
              stagger: 0.05,
              delay: 0.15,
              ease: 'power4.out',
              overwrite: 'auto'
            });
          } else {
            if (enterAnim) enterAnim.kill();
            leaveAnim = gsap.to(items, {
              autoAlpha: 0,
              duration: 0.25,
              stagger: { from: 'end', each: 0.02 },
              ease: 'power4.inOut',
              overwrite: 'auto',
              onComplete: () => gsap.set(area, { opacity: 0 })
            });
          }
        });
      } else {
        d.addEventListener('pointerenter', () => {
          clearTimeout(hideTimeout);
          d.classList.add('hovered');
          if (leaveAnim) leaveAnim.kill();
          gsap.set(area, { opacity: 1 });
          enterAnim = gsap.fromTo(items, { autoAlpha: 0 }, {
            autoAlpha: 1,
            duration: 0.6,
            stagger: 0.05,
            delay: 0.15,
            ease: 'power4.out',
            overwrite: 'auto'
          });
        });
        d.addEventListener('pointerleave', () => {
          hideTimeout = setTimeout(() => {
            d.classList.remove('hovered');
            if (enterAnim) enterAnim.kill();
            leaveAnim = gsap.to(items, {
              autoAlpha: 0,
              duration: 0.25,
              stagger: { from: 'end', each: 0.02 },
              ease: 'power3.inOut',
              overwrite: 'auto',
              onComplete: () => gsap.set(area, { opacity: 0 })
            });
          }, 100);
        });
      }
    });
  }); // end of .page_main loop
});   // end of DOMContentLoaded
</script></div><style>:root {--site--margin: clamp(1.25rem, 0.7954545454545454rem + 2.272727272727273vw, 2.5rem);--_typography---font-size--display: clamp(3rem, 1.9090909090909092rem + 5.454545454545454vw, 6rem);--_typography---font-size--h1: clamp(2.25rem, 1.4318181818181819rem + 4.090909090909091vw, 4.5rem);--_typography---font-size--h2: clamp(1.75rem, 1.2045454545454546rem + 2.727272727272727vw, 3.25rem);--_typography---font-size--h3: clamp(1.75rem, 1.3863636363636365rem + 1.8181818181818181vw, 2.75rem);--_typography---font-size--h4: clamp(1.5rem, 1.3181818181818181rem + 0.9090909090909091vw, 2rem);--_typography---font-size--h5: clamp(1.25rem, 1.1590909090909092rem + 0.45454545454545453vw, 1.5rem);--_typography---font-size--h6: clamp(1rem, 0.9545454545454546rem + 0.22727272727272727vw, 1.125rem);--_typography---font-size--text-large: clamp(1.25rem, 1.1590909090909092rem + 0.45454545454545453vw, 1.5rem);--_typography---font-size--text-main: clamp(0.9375rem, 0.8920454545454546rem + 0.22727272727272727vw, 1.0625rem);--_typography---font-size--text-small: clamp(0.875rem, 0.8295454545454546rem + 0.22727272727272727vw, 1rem);--_spacing---space--1: clamp(0.5rem, 0.45454545454545453rem + 0.22727272727272727vw, 0.625rem);--_spacing---space--2: clamp(0.625rem, 0.5795454545454546rem + 0.22727272727272727vw, 0.75rem);--_spacing---space--3: clamp(1rem, 0.9545454545454546rem + 0.22727272727272727vw, 1.125rem);--_spacing---space--4: clamp(1.25rem, 1.1590909090909092rem + 0.45454545454545453vw, 1.5rem);--_spacing---space--5: clamp(1.75rem, 1.4772727272727273rem + 1.3636363636363635vw, 2.5rem);--_spacing---space--6: clamp(2.25rem, 1.7954545454545454rem + 2.272727272727273vw, 3.5rem);--_spacing---space--7: clamp(3rem, 2.272727272727273rem + 3.6363636363636362vw, 5rem);--_spacing---space--8: clamp(4rem, 2.727272727272727rem + 6.363636363636363vw, 7.5rem);--_spacing---section-space--small: clamp(3rem, 2.272727272727273rem + 3.6363636363636362vw, 5rem);--_spacing---section-space--main: clamp(3.5rem, 2.227272727272727rem + 6.363636363636363vw, 7rem);--_spacing---section-space--large: clamp(5rem, 3.4545454545454546rem + 7.727272727272727vw, 9.25rem);--_spacing---section-space--page-top: clamp(7rem, 5.454545454545454rem + 7.727272727272727vw, 11.25rem);--_spacing---section-space--xsmall: clamp(0.5rem, 0.3181818181818182rem + 0.9090909090909091vw, 1rem);--_typography---font-size--text-xsmall: clamp(0.75rem, 0.7045454545454546rem + 0.22727272727272727vw, 0.875rem);}</style></div><main id="main" class="page_main"><section class="hero_utility-page_wrap"><div class="hero_utility-page_contain u-container"><div class="hero_utility-page_content"><div><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 47 59" width="3rem"><path fill-rule="evenodd" d="M0 0H30.5L47 16.5V59H0V0ZM21 19H26V34H21V19ZM21 39H26V44H21V39Z" fill="currentColor"></path></svg></div><div class="hero_utility-page_header"><h1 class="hero_utility-page_title u-text-style-h2">Page Not Found</h1><div class="hero_utility-page_text u-text-style-main">The page you are looking for doesn&#x27;t exist or has been moved</div></div></div></div></section></main></div><script src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=68108d68d0fc0cfa0c26dbc9" type="text/javascript" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/68108d68d0fc0cfa0c26dbc9/js/webflow.0b6e640e.f73343fe9c88ae5c.js" type="text/javascript" integrity="sha384-h8k8JxGJfVK/fIaWDR5G7g3q1BcVIhdO8kvxCC3Yc3xkS+kSgF09Qe17rwbeuTs+" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/gsap.min.js" type="text/javascript"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/ScrollTrigger.min.js" type="text/javascript"></script><script src="https://cdn.prod.website-files.com/gsap/3.14.2/SplitText.min.js" type="text/javascript"></script><script type="text/javascript">gsap.registerPlugin(ScrollTrigger,SplitText);</script><!-- SwiperJS Library -->
<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js" defer></script>

<script>

document.addEventListener('DOMContentLoaded', () => {
  const io = new IntersectionObserver((entries, obs) => {
    entries.forEach(({ isIntersecting, target }) => {
      if (!isIntersecting) return;
      target.querySelectorAll('source[data-src]').forEach(s => {
        s.src = s.dataset.src;
        s.removeAttribute('data-src');
      });
      target.load();
      // muted + playsinline lets autoplay work on iOS
      target.play().catch(() => {});
      obs.unobserve(target);
    });
  }, { rootMargin: '300px 0px' });

  document.querySelectorAll('video.g_visual_video').forEach(v => {
    v.muted = true; // ensure runtime state
    io.observe(v);
  });
  
  var yearEl = document.getElementById("disclaimer-year");
    if (yearEl) {
      yearEl.innerHTML = new Date().getFullYear();
    }
});

(function () {
  const FORM_SEL = '.form_main_wrap';          // change to your form wrapper
  const container = document.getElementById('recaptcha');
  const siteKey = container?.dataset.sitekey;
  if (!container || !siteKey) return;

  let apiLoaded = false, widgetRendered = false, widgetId = null;

  function loadApi(cb) {
    if (apiLoaded) return cb && cb();
    window.onRecaptchaLoad = function () { apiLoaded = true; cb && cb(); };
    const s = document.createElement('script');
    s.src = 'https://www.google.com/recaptcha/api.js?onload=onRecaptchaLoad&render=explicit';
    s.async = true; s.defer = true;
    document.head.appendChild(s);
  }

  function renderWidget() {
    if (widgetRendered || !window.grecaptcha) return;
    widgetId = grecaptcha.render(container, {
      sitekey: siteKey,
      callback: onSolved,
      'expired-callback': onExpired
    });
    widgetRendered = true;
  }

  function triggerLoad() { loadApi(renderWidget); }

  function onSolved() { /* optionally enable submit button */ }
  function onExpired() { /* optionally disable submit button */ }

  const form = document.querySelector(FORM_SEL);
  if (!form) return;

  // 1) Load when the form becomes visible (with some prefetch margin)
  const io = new IntersectionObserver((entries, obs) => {
    if (entries.some(e => e.isIntersecting)) { triggerLoad(); obs.disconnect(); }
  }, { rootMargin: '200px' });
  io.observe(form);

  // 2) Or load on first user interaction
  ['focus','click','touchstart','mouseover'].forEach(ev => {
    form.addEventListener(ev, triggerLoad, { once: true, passive: true });
  });

  // 3) Safety: if user submits before solving, load & block submit
  form.addEventListener('submit', (e) => {
    if (!widgetRendered || (window.grecaptcha && !grecaptcha.getResponse(widgetId))) {
      e.preventDefault();
      triggerLoad();
      container.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
})();

</script><script src="https://hubspotonwebflow.com/assets/js/form-124.js" type="text/javascript" integrity="sha384-bjyNIOqAKScdeQ3THsDZLGagNN56B4X2Auu9YZIGu+tA/PlggMk4jbWruG/P6zYj" crossorigin="anonymous"></script></body></html>